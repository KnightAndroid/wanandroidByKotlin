<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="title"
            type="java.lang.String" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:id="@+id/set_ll_version_record"
        >



        <include
            android:id="@+id/include_version_record_toolbar"
            layout="@layout/base_include_toolbar"
            app:title="@{title}"/>

        <include
            android:id="@+id/include_version_record_collectfreshalayout"
            layout="@layout/base_layout_recycleview"/>
    </LinearLayout>
</layout>


